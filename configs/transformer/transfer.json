{
  "name": "transformer_place_to_stack",
  "seed": 11,
  "total_steps": 6000000,
  "device": "auto",
  "checkpoint_dir": "checkpoints/transformer",
  "log_dir": "runs/transformer",
  "log_interval_updates": 5,
  "save_interval_updates": 25,
  "resume_checkpoint": "checkpoints/transformer/transformer_place_best.pt",
  "train_task_indices": null,
  "model": {
    "text_model_name": "sentence-transformers/all-MiniLM-L6-v2",
    "text_backend": "pretrained",
    "max_language_tokens": 32,
    "d_model": 256,
    "n_layers": 4,
    "n_heads": 8,
    "dim_feedforward": 1024,
    "dropout": 0.1,
    "state_mlp_hidden": 256,
    "actor_hidden": 256,
    "min_log_std": -5.0,
    "max_log_std": 0.0
  },
  "ppo": {
    "learning_rate": 0.00015,
    "transfer_learning_rate": 0.00005,
    "text_projection_learning_rate": 0.00003,
    "rollout_steps": 4096,
    "epochs": 6,
    "batch_size": 256,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "clip_epsilon": 0.1,
    "value_coefficient": 0.5,
    "entropy_coefficient": 0.002,
    "max_grad_norm": 0.5,
    "target_kl": 0.02,
    "weight_decay": 0.0001
  },
  "curriculum": {
    "phase": "transfer",
    "rolling_episodes": 80,
    "minimum_episodes": 40,
    "cooldown_updates": 20,
    "earlier_stage_probability": 0.0,
    "stage_success_threshold": 0.75,
    "transport_success_threshold": 0.6,
    "curriculum_distance_start": 0.1,
    "curriculum_distance_max": 0.34,
    "curriculum_distance_step": 0.02,
    "lift_height_start": 0.02,
    "lift_height_step": 0.01,
    "stack_fraction_start": 0.1,
    "stack_fraction_max": 0.5,
    "stack_fraction_step": 0.05,
    "stack_success_threshold": 0.25,
    "place_retention_threshold": 0.55,
    "shared_grasp_threshold": 0.65,
    "shared_lift_threshold": 0.6,
    "paraphrase_probability": 0.5
  }
}
